# ─────────────────────────────────────────────────────────────────────────────
# AutoJustice AI NEXUS — Environment Configuration Template
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core App ──────────────────────────────────────────────────────────────────
APP_NAME=AutoJustice AI NEXUS
APP_VERSION=2.0.0
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_me_with_64_hex_chars_from_secrets_token_hex_32

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Default admin credentials — CHANGE THESE IMMEDIATELY IN PRODUCTION
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=AutoJustice@2024!

# ── AI Services ───────────────────────────────────────────────────────────────
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-key-here
GEMINI_MODEL=gemini-1.5-pro

# Full path to Tesseract executable
# Linux/Mac: tesseract   (if in PATH)
# Windows:   C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_PATH=tesseract

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default prototype):
DATABASE_URL=sqlite:///./autojustice.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/autojustice

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
FIR_OUTPUT_DIR=firs
MAX_UPLOAD_SIZE_MB=25

# ── Risk Engine Thresholds ────────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.70
MEDIUM_RISK_THRESHOLD=0.40
FAKE_REPORT_THRESHOLD=0.45

# ── Image Forensics ───────────────────────────────────────────────────────────
ELA_QUALITY=90
ELA_TAMPER_THRESHOLD=0.55

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SUBMISSIONS_PER_HOUR=5

# ── Police Station Identity ───────────────────────────────────────────────────
STATION_NAME=Cyber Crime Police Station
STATION_ADDRESS=Commissioner Office, Cyber Cell, Mumbai - 400001
STATION_CODE=MH-CC-001
STATION_STATE=Maharashtra
STATION_DISTRICT=Mumbai City

# ── SMTP Notifications (optional) ─────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@autojustice.gov.in
